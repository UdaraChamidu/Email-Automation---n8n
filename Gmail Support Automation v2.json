    {
      "parameters": {
        "jsCode": "const body = $json.raw_body || \"\";\n\n// Remove common reply patterns\nlet cleaned = body\n  .replace(/On .* wrote:/gs, '')\n  .replace(/From:.*$/gim, '')\n  .replace(/Sent:.*$/gim, '')\n  .replace(/To:.*$/gim, '')\n  .replace(/Subject:.*$/gim, '')\n  .replace(/Best regards[\\s\\S]*$/gim, '')\n  .replace(/Regards[\\s\\S]*$/gim, '')\n  .replace(/Thank you[\\s\\S]*$/gim, '')\n  .replace(/________________________________/g, '')\n  .trim();\n\n// Remove excessive empty lines\ncleaned = cleaned.replace(/\\n\\s*\\n/g, '\\n\\n');\n\n\n// Convert received date/time to Eastern Time\n// Use the date field that comes from Gmail/Edit Fields\nconst originalDate =\n  $json.received_at ||\n  $json.date ||\n  $json.internalDate ||\n  $json.email_date ||\n  $json.headers?.date;\n\nconst emailDate = originalDate\n  ? new Date(Number(originalDate) || originalDate)\n  : new Date();\n\nconst received_date = emailDate.toLocaleDateString(\"en-US\", {\n  timeZone: \"America/New_York\",\n  year: \"numeric\",\n  month: \"2-digit\",\n  day: \"2-digit\",\n});\n\nconst received_time = emailDate.toLocaleTimeString(\"en-US\", {\n  timeZone: \"America/New_York\",\n  hour: \"2-digit\",\n  minute: \"2-digit\",\n  second: \"2-digit\",\n  hour12: true,\n});\n\nreturn [\n  {\n    json: {\n      ...$json,\n      clean_body: cleaned,\n      received_date,\n      received_time,\n      timezone: \"America/New_York\"\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        208,
        112
      ],
      "id": "e26fb370-ec26-4c02-9805-27e701c5fbaa",
