      "parameters": {
        "jsCode": "const original = $json;\n\nconst aiData = original.output[0].content[0].text;\n\n// Remove \"Date: \"\nconst rawDate = original.received_at.replace(\"Date: \", \"\");\n\n// Convert to JS Date object\nconst parsedDate = new Date(rawDate);\n\n// Separate date and time\nconst onlyDate = parsedDate.toISOString().split(\"T\")[0];\n\nconst onlyTime = parsedDate.toTimeString().split(\" \")[0];\n\nreturn [\n  {\n    json: {\n      customer_email: original.customer_email,\n      customer_name: original.customer_name,\n      delivered_to: original.delivered_to,\n      \n      received_at: original.received_at,\n      received_date: original.received_date,\n      received_time: original.received_time,\n      timezone: original.timezone,\n      \n      subject: original.subject,\n      clean_body: original.clean_body,\n\n      category: aiData.category,\n      priority: aiData.priority,\n      sentiment: aiData.sentiment,\n      requires_human: aiData.requires_human,\n      confidence_score: aiData.confidence_score,\n\n      thread_id: original.thread_id\n      \n    }\n  }\n,];"
      },
